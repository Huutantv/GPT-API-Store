ANTHROPIC_AUTH_TOKEN=sk-backend-key-1,sk-backend-key-2
ANTHROPIC_BASE_URL=https://hk.doro.lol/v1

ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5-20251001
CLAUDE_CODE_SUBAGENT_MODEL=opus

DORO_BACKEND_MODEL=minimax-m2.5

# Backend 2 (TokenRouter / MiniMax-M3)
# Set DORO_ACTIVE_BACKEND=2 to use only backend 2, or "both" for failover/router mode.
DORO_BACKEND2_NAME=TokenRouter MiniMax
DORO_BACKEND2_BASE_URL=https://api.tokenrouter.com/v1
DORO_BACKEND2_AUTH_TOKEN=
DORO_BACKEND2_MODEL=MiniMax-M3
DORO_BACKEND2_DISABLE_TOOLS=false

DORO_PROXY_PORT=4000
DORO_PROXY_KEYS=sk-user1-abc123,sk-user2-def456
DORO_PROXY_WORKERS=2
DORO_MAX_CONCURRENT=50
DORO_CODEX_MAX_OUTPUT_TOKENS=16384
DORO_BODY_LIMIT=50mb

# Server-side AI tools (read-only allowlist for public API users)
DORO_SERVER_TOOLS_ENABLED=true
DORO_SERVER_TOOLS_MAX_ROUNDS=2




# Đường dẫn truy cập dashboard (nên để khó đoán).
# Mặc định: /dashboard_@@admin
DORO_DASHBOARD_PATH=/dashboard_@@admin
DORO_ADMIN_PATH=/admin9797

# ── Thanh toán ──
BANK_ACCOUNT=0123456789
BANK_CODE=MB
BANK_OWNER=NGUYEN VAN A
BANK_NAME=MB Bank
DORO_PUBLIC_URL=https://zplay.io.vn

# ── Email (Gmail SMTP) ──
MAIL_USER=your@gmail.com
MAIL_PASS=your-app-password

# ── Webhook secrets ──
SEPAY_WEBHOOK_SECRET=
CASSO_WEBHOOK_SECRET=

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Model Fallback ──
# Thứ tự ưu tiên model (cách nhau bởi dấu phẩy)
DORO_MODEL_FALLBACK=gpt-5.5,gpt-5.5-high,gpt-5.5-xhigh,gpt-5.4,gpt-5.3-codex
# Ngưỡng mặc định chuyển model (requests/ngày) cho model không có limit riêng
DORO_MODEL_DAILY_LIMIT=1800
# Limit riêng per model (từ VietAPI dashboard). Format: model:limit,model:limit
# gpt-5.5, gpt-5.5-high, gpt-5.5-xhigh: 2000 rq/ngày
# claude-opus-4.6, claude-opus-4.7: 200 rq/ngày
# gpt-5.4, gpt-5.3-codex: theo quota token (không giới hạn request)
DORO_MODEL_LIMITS=gpt-5.5:2000,gpt-5.5-high:2000,gpt-5.5-xhigh:2000,claude-opus-4.6:200,claude-opus-4.7:200

# ── Quota Check ──
# Key riêng cho check quota (nếu khác backend key)
DORO_QUOTA_KEY=

# ?? IP Guard (ch?ng DDoS / l?m d?ng) ??
# B?t/t?t module b?o v? IP. ??t false s? t?t ho?n to?n auto-ban.
DORO_IPGUARD_ENABLED=true
# Ng??ng requests/gi?y tr?n 1 IP. V??t s? b? auto ban.
DORO_IPGUARD_RPS_LIMIT=20
# Ng??ng requests/ph?t tr?n 1 IP.
DORO_IPGUARD_RPM_LIMIT=400
# Ng??ng s? request kh?ng c? / sai key trong 60s.
DORO_IPGUARD_UNAUTH_LIMIT=30
# Ng??ng s? response 4xx trong 60s (path scanner, brute force).
DORO_IPGUARD_ERR4XX_LIMIT=60
# Th?i gian ban m?c ??nh khi auto-ban (ph?t).
DORO_IPGUARD_AUTO_BAN_MINUTES=60
# IP / CIDR kh?ng bao gi? b? ban (c?ch nhau b?i d?u ph?y).
DORO_IPGUARD_WHITELIST=127.0.0.1,::1,::ffff:127.0.0.1
# ??c CF-Connecting-IP n?u ??t sau Cloudflare (khuy?n ngh? b?t).
DORO_IPGUARD_TRUST_CF=true

# ?? Key Health (per-backend-key optimization) ??
# Th?i gian t?m kh?a key khi g?p 401/403/quota (ph?t)
DORO_KEY_SICK_MINUTES=10
# Th?i gian cooldown key b? 429 rate limit (gi?y)
DORO_KEY_COOLDOWN_SECONDS=60
